generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Place {
  id        String   @id @default(cuid())
  city      String
  country   String
  createdAt DateTime @default(now())
  entries   Entry[]

  @@map("places")
}

model Entry {
  id          String      @id @default(cuid())
  placeId     String
  title       String
  description String
  rating      Int
  category    String
  visitDate   DateTime?
  createdAt   DateTime    @default(now())
  place       Place       @relation(fields: [placeId], references: [id], onDelete: Cascade)
  images      EntryImage[]
  trips       TripEntry[]

  @@index([placeId])
  @@map("entries")
}

model Trip {
  id        String      @id @default(cuid())
  name      String
  createdAt DateTime    @default(now())
  entries   TripEntry[]

  @@map("trips")
}

model Wishlist {
  id        String   @id @default(cuid())
  place     String
  country   String
  status    String
  note      String?
  createdAt DateTime @default(now())

  @@map("wishlist")
}

model EntryImage {
  id        String   @id @default(cuid())
  entryId   String
  imageUrl  String
  createdAt DateTime @default(now())
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
  @@map("entryImages")
}

model TripEntry {
  tripId  String
  entryId String
  trip    Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  entry   Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@id([tripId, entryId])
  @@index([entryId])
  @@map("tripEntries")
}
